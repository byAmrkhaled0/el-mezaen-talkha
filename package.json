{
  "name": "el-mezaen-talakh-booking",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/clean-dist.mjs && node scripts/generate-seo.mjs && vite build",
    "verify:build": "node scripts/verify-build.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --test tests/*.test.mjs",
    "test:functions": "npm --prefix functions test",
    "test:emulator": "firebase emulators:exec --only functions,firestore,auth --project demo-el-mezaen \"FIREBASE_PROJECT_ID=demo-el-mezaen node scripts/seed-firestore.mjs && node tests/emulator-smoke.mjs\"",
    "seed": "node scripts/seed-firestore.mjs",
    "create-admin": "node scripts/create-admin.mjs"
  },
  "dependencies": {
    "@fontsource/alexandria": "^5.2.8",
    "@fontsource/tajawal": "^5.2.7",
    "firebase": "^12.2.1",
    "jsbarcode": "^3.12.1"
  },
  "devDependencies": {
    "firebase-admin": "^14.2.0",
    "firebase-tools": "^15.24.0",
    "vite": "^7.0.6"
  }
}
