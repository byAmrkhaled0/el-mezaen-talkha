rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function canManageMedia() {
      return request.auth != null && (request.auth.token.role == 'admin' || (request.auth.token.role == 'manager' && request.auth.token.permissions is list && request.auth.token.permissions.hasAny(['gallery', 'celebrities', 'posts', 'settings'])));
    }
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if canManageMedia()
        && (
          (request.resource.size < 5 * 1024 * 1024
            && request.resource.contentType.matches('image/(jpeg|png|webp|avif)'))
          ||
          (request.resource.size < 30 * 1024 * 1024
            && request.resource.contentType.matches('video/(mp4|webm)'))
        );
    }
    match /{allPaths=**} { allow read, write: if false; }
  }
}
