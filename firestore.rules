rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    // The public site reads catalog and creates bookings through Cloud Functions only.
    // This prevents direct reads of customer data and browser-side price manipulation.
    match /{document=**} {
      allow read, write: if false;
    }

    // A signed-in user may read only their own minimal profile.
    match /users/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list, create, update, delete: if false;
    }
  }
}
